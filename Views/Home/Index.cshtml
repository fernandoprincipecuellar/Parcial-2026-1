@{
    ViewData["Title"] = "Bienvenido a CrediApp";
}

<div class="hero-gradient text-center mb-5">
    <div class="container animate-fade-in">
        <h1 class="display-3 mb-3">Tu crédito, <span class="text-primary">al instante</span></h1>
        <p class="lead mb-5 text-muted mx-auto" style="max-width: 600px;">
            Obtén la liquidez que necesitas con nuestra plataforma inteligente de gestión de créditos. 
            Transparente, rápido y 100% digital.
        </p>
        <div class="d-flex justify-content-center gap-3">
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">Comenzar Ahora</a>
                <a class="btn btn-outline-dark btn-lg" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
            }
            else
            {
                <a class="btn btn-primary btn-lg" asp-controller="Solicitudes" asp-action="Create">Nueva Solicitud</a>
                <a class="btn btn-outline-dark btn-lg" asp-controller="Solicitudes" asp-action="Index">Mis Créditos</a>
            }
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 p-4 border-0">
                <div class="stat-icon icon-blue mx-auto mb-3">
                    <i class="bi bi-lightning-charge"></i>
                </div>
                <h3>Aprobación Rápida</h3>
                <p class="text-muted">Nuestro sistema evalúa tu solicitud en segundos utilizando algoritmos avanzados.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 border-0">
                <div class="stat-icon icon-purple mx-auto mb-3">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h3>100% Seguro</h3>
                <p class="text-muted">Tus datos están protegidos con los más altos estándares de seguridad bancaria.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 border-0">
                <div class="stat-icon icon-red mx-auto mb-3">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h3>Mejor Tasa</h3>
                <p class="text-muted">Ofrecemos tasas competitivas basadas en tu perfil de ingresos mensuales.</p>
            </div>
        </div>
    </div>
</div>

<div class="bg-dark text-white py-5 mt-5 rounded-5 overflow-hidden position-relative">
    <div class="container text-center py-5">
        <h2 class="mb-4">¿Listo para hacer realidad tus proyectos?</h2>
        <p class="mb-4 opacity-75">Únete a miles de personas que ya confían en CrediApp.</p>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">Crear Cuenta Gratis</a>
        }
    </div>
</div>
