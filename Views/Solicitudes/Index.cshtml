@model IEnumerable<Parcial_2026_1.Models.SolicitudCredito>
@using Parcial_2026_1.Models

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Gestión de Créditos</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i> Nueva Solicitud
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 mb-4 shadow-sm">
    <div class="card-body p-4">
        <h5 class="card-title mb-4"><i class="bi bi-filter me-2 text-primary"></i> Filtros de Búsqueda</h5>
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Estado</label>
                <select name="estado" class="form-select border-0 bg-light">
                    <option value="">Todos los estados</option>
                    @foreach (var val in Enum.GetValues(typeof(EstadoSolicitud)))
                    {
                        @if (ViewBag.Estado?.ToString() == val.ToString())
                        {
                            <option value="@val" selected>@val</option>
                        }
                        else
                        {
                            <option value="@val">@val</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Monto Mínimo</label>
                <input type="number" name="montoMin" class="form-control border-0 bg-light" value="@ViewBag.MontoMin" placeholder="S/. 0.00">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Monto Máximo</label>
                <input type="number" name="montoMax" class="form-control border-0 bg-light" value="@ViewBag.MontoMax" placeholder="S/. 0.00">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Desde</label>
                <input type="date" name="fechaInicio" class="form-control border-0 bg-light" value="@ViewBag.FechaInicio">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Hasta</label>
                <input type="date" name="fechaFin" class="form-control border-0 bg-light" value="@ViewBag.FechaFin">
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
            </div>
            <div class="col-12 mt-2">
                <a asp-action="Index" class="text-decoration-none small text-muted">
                    <i class="bi bi-x-circle"></i> Limpiar filtros
                </a>
            </div>
        </form>
        <div asp-validation-summary="All" class="text-danger small mt-3"></div>
    </div>
</div>

<div class="table-container border-0">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Monto</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="fw-bold">@item.FechaSolicitud.ToString("dd MMM, yyyy")</span>
                            <span class="text-muted small">@item.FechaSolicitud.ToString("HH:mm")</span>
                        </div>
                    </td>
                    <td>
                        <span class="fs-5 fw-bold text-dark">S/. @item.MontoSolicitado.ToString("N2")</span>
                    </td>
                    <td>
                        @switch (item.Estado)
                        {
                            case EstadoSolicitud.Pendiente:
                                <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i> @item.Estado</span>
                                break;
                            case EstadoSolicitud.Aprobado:
                                <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i> @item.Estado</span>
                                break;
                            case EstadoSolicitud.Rechazado:
                                <span class="badge bg-danger"><i class="bi bi-x-lg me-1"></i> @item.Estado</span>
                                break;
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-3 px-3 shadow-sm">
                            <i class="bi bi-info-circle me-1"></i> Detalles
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted opacity-25 mb-3">
                <i class="bi bi-folder-x"></i>
            </div>
            <p class="text-muted">No se encontraron solicitudes que coincidan con los criterios.</p>
        </div>
    }
</div>
