@model IEnumerable<Parcial_2026_1.Models.SolicitudCredito>
@using Parcial_2026_1.Models

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="container mt-4">
    <h1 class="mb-4">@ViewData["Title"]</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">Filtros de Búsqueda</h5>
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select name="estado" class="form-select">
                        <option value="">Todos</option>
                        @foreach (var val in Enum.GetValues(typeof(EstadoSolicitud)))
                        {
                            <option value="@val" selected="@(ViewBag.Estado?.ToString() == val.ToString())">@val</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Monto Mínimo</label>
                    <input type="number" step="0.01" name="montoMin" class="form-control" value="@ViewBag.MontoMin" />
                    <span class="text-danger">@Html.ValidationMessage("montoMin")</span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Monto Máximo</label>
                    <input type="number" step="0.01" name="montoMax" class="form-control" value="@ViewBag.MontoMax" />
                    <span class="text-danger">@Html.ValidationMessage("montoMax")</span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" name="fechaInicio" class="form-control" value="@ViewBag.FechaInicio" />
                    <span class="text-danger">@Html.ValidationMessage("fechaInicio")</span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" name="fechaFin" class="form-control" value="@ViewBag.FechaFin" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </form>
            <div class="mt-2">
                <a asp-action="Index" class="btn btn-link btn-sm">Limpiar Filtros</a>
            </div>
        </div>
    </div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    foreach (var error in modelState.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Fecha</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.MontoSolicitado.ToString("C2")</td>
                        <td>
                            <span class="badge @(item.Estado switch {
                                EstadoSolicitud.Aprobado => "bg-success",
                                EstadoSolicitud.Rechazado => "bg-danger",
                                _ => "bg-warning text-dark"
                            })">
                                @item.Estado
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-info-circle"></i> Ver Detalles
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center mt-5">
            <p class="text-muted">No se encontraron solicitudes que coincidan con los criterios.</p>
        </div>
    }
</div>
