@model Parcial_2026_1.Models.SolicitudCredito

@{
    ViewData["Title"] = "Solicitar Nuevo Crédito";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg p-4">
            <div class="text-center mb-4">
                <div class="stat-icon icon-purple mx-auto mb-3">
                    <i class="bi bi-piggy-bank"></i>
                </div>
                <h1 class="h3">Nueva Solicitud</h1>
                <p class="text-muted">Ingresa el monto que necesitas para iniciar tu evaluación.</p>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small"></div>
                
                <div class="form-floating mb-4">
                    <input asp-for="MontoSolicitado" class="form-control border-0 bg-light fs-4 fw-bold text-center" 
                           placeholder="0.00" style="height: 100px;" />
                    <label asp-for="MontoSolicitado">Monto a Solicitar (S/.)</label>
                    <span asp-validation-for="MontoSolicitado" class="text-danger small"></span>
                </div>

                <div class="alert alert-info border-0 shadow-sm small mb-4">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Recuerda que el monto máximo está sujeto a tus ingresos mensuales declarados.
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg py-3">
                        <i class="bi bi-send me-2"></i> Enviar Solicitud
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-lg py-3 border-0">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
