@using System.Text.Json
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parcial_2026_1</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Parcial_2026_1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-wallet2 me-2"></i> CrediApp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Solicitudes" asp-action="Index">
                                    <i class="bi bi-file-earmark-text me-1"></i> Mis Solicitudes
                                </a>
                            </li>
                            if (User.IsInRole("Analista"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary" asp-controller="Analista" asp-action="Index">
                                        <i class="bi bi-speedometer2 me-1"></i> Panel Analista
                                    </a>
                                </li>
                            }
                            var ultimaSolicitud = Context.Session.GetString("ultima_solicitud");
                            if (!string.IsNullOrEmpty(ultimaSolicitud))
                            {
                                var data = JsonSerializer.Deserialize<JsonElement>(ultimaSolicitud);
                                var solId = data.GetProperty("Id").GetInt32();
                                var solMonto = data.GetProperty("Monto").GetDecimal();
                                <li class="nav-item">
                                    <a class="nav-link text-info fw-bold" asp-controller="Solicitudes" asp-action="Details" asp-route-id="@solId">
                                        <i class="bi bi-eye me-1"></i> Última: S/. @solMonto.ToString("N2")
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3 mt-4 animate-fade-in">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container text-center">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5 class="text-dark">CrediApp</h5>
                    <p class="small">Plataforma inteligente para la gestión de créditos personales.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5 class="text-dark">Enlaces</h5>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Inicio</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">Privacidad</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="text-dark">Contacto</h5>
                    <p class="small">Soporte: ayuda@crediapp.com</p>
                    <div class="d-flex justify-content-center gap-3">
                        <i class="bi bi-facebook fs-5"></i>
                        <i class="bi bi-twitter-x fs-5"></i>
                        <i class="bi bi-linkedin fs-5"></i>
                    </div>
                </div>
            </div>
            <hr class="my-4">
            <span class="small">&copy; 2026 - CrediApp - Parcial 2026-1</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
